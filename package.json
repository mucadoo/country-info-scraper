{
  "name": "@mucadoo/wiki-geo-data",
  "version": "0.1.15",
  "browser": {
    "fs": false,
    "path": false,
    "url": false
  },
  "description": "A modern, high-performance TypeScript-based web scraper that extracts comprehensive geographical and political information from Wikipedia and publishes it as a live JSON API.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "data/sovereign-states.json",
    "data/sovereign-states.min.json",
    "data/sovereign-states.csv",
    "data/schema.json",
    "data/DATA_MODEL.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "scripts": {
    "start": "node --loader ts-node/esm src/main.ts",
    "build": "tsc",
    "build:sdk": "tsup",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts' 'scripts/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' 'scripts/**/*.ts' --fix",
    "scrape": "node dist/src/scraper/main.js",
    "canary": "node --loader ts-node/esm src/canary.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npx tsx scripts/audit-data.ts",
    "verify:loc": "npx tsx scripts/verify-localization.ts",
    "validate": "npm run audit && npm run verify:loc",
    "generate-docs": "npx tsx scripts/generate-docs.ts",
    "generate-csv": "npx tsx scripts/generate-csv.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mucadoo/wikigeo-data-scraper.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mucadoo/wikigeo-data-scraper/issues"
  },
  "homepage": "https://github.com/mucadoo/wikigeo-data-scraper#readme",
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/axios": "^0.9.36",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/ui": "^4.1.5",
    "axios": "^1.16.0",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "crawlee": "^3.16.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod-to-json-schema": "^3.25.2"
  }
}
