{
  "name": "country-info-scraper",
  "version": "1.0.0",
  "description": "A modern, high-performance Java-based web scraper that extracts comprehensive information about sovereign states from Wikipedia and publishes it as a live JSON API.",
  "type": "module",
  "scripts": {
    "start": "node --loader ts-node/esm src/main.ts",
    "build": "tsc",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "scrape": "node dist/src/main.js",
    "canary": "node --loader ts-node/esm src/canary.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mucadoo/country-info-scraper.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mucadoo/country-info-scraper/issues"
  },
  "homepage": "https://github.com/mucadoo/country-info-scraper#readme",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "crawlee": "^3.16.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
