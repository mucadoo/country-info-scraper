{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "minItems": 193,
  "items": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "minLength": 2
      },
      "ISO_code": {
        "type": "string",
        "pattern": "^([A-Z]{2,3}|N/A)$"
      },
      "flagUrl": {
        "type": "string"
      },
      "description": {
        "type": "string",
        "minLength": 50
      },
      "capital": {
        "type": "string",
        "minLength": 2
      },
      "largest_city": {
        "type": "string",
        "minLength": 2
      },
      "population": {
        "type": "integer",
        "minimum": 0
      },
      "area_km2": {
        "type": "number",
        "minimum": 0
      },
      "density_km2": {
        "type": "number",
        "minimum": 0
      },
      "government": {
        "type": "string",
        "minLength": 3
      },
      "official_language": {
        "type": "string",
        "minLength": 2
      },
      "demonym": {
        "type": "string",
        "minLength": 2
      },
      "gdp": {
        "type": ["number", "null"]
      },
      "hdi": {
        "type": ["number", "null"]
      },
      "currency": {
        "type": "string",
        "minLength": 3
      },
      "time_zone": {
        "type": "string",
        "minLength": 3
      },
      "calling_code": {
        "type": "string",
        "minLength": 1
      },
      "internet_TLD": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": [
      "name",
      "ISO_code",
      "flagUrl",
      "description",
      "capital",
      "largest_city",
      "population",
      "area_km2",
      "density_km2",
      "government",
      "official_language",
      "demonym",
      "gdp",
      "hdi",
      "currency",
      "time_zone",
      "calling_code",
      "internet_TLD"
    ]
  }
}
